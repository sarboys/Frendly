NODE_ENV=production
CORS_ORIGIN=https://frendly.tech,https://www.frendly.tech,https://admin.frendly.tech,https://partner.frendly.tech
LANDING_DIR=/opt/frendly/landing
ADMIN_DIR=/opt/frendly/admin
ADMIN_API_BASE_URL=https://api.frendly.tech
ADMIN_BOOTSTRAP_EMAIL=admin@frendly.tech
ADMIN_BOOTSTRAP_PASSWORD=change-me-now
ADMIN_COOKIE_DOMAIN=.frendly.tech
COMPOSE_EXTRA_FILES=
CORE_SERVICES=postgres redis pgbouncer
RUNTIME_SERVICES=api chat worker landing admin_internal admin_partner
NGINX_SERVICE=nginx

POSTGRES_DB=frendly
POSTGRES_USER=frendly
POSTGRES_PASSWORD=change-me-now
DATABASE_DIRECT_URL=postgresql://frendly:change-me-now@postgres:5432/frendly
DATABASE_POOL_URL=postgresql://frendly:change-me-now@pgbouncer:6432/frendly?pgbouncer=true&connection_limit=3&pool_timeout=10
POSTGRES_STATEMENT_TIMEOUT=15s
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
POSTGRES_LOG_MIN_DURATION_STATEMENT=500
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=10
RUN_DB_SEED=false
ENABLE_TESTING_ACCESS=false
CHAT_UNREAD_COUNTER_READS=false
WORKER_OUTBOX_BATCH_CLAIM=false
WORKER_OUTBOX_ENABLED=true
WORKER_CONTENT_ENABLED=true
WORKER_SCHEDULES_ENABLED=true
WORKER_OUTBOX_PROCESSING_CONCURRENCY=1
WORKER_MAX_EVENTS_PER_RUN=25
WORKER_PUSH_CONCURRENCY=5
WORKER_PUSH_TOKEN_BATCH_SIZE=20
WORKER_BUS_PUBLISH_CONCURRENCY=25
WORKER_MESSAGE_NOTIFICATION_BATCH_SIZE=500
WORKER_RETENTION_CLEANUP_ENABLED=false
WORKER_RETENTION_CLEANUP_INTERVAL_MS=21600000
CONTENT_IMPORT_ENABLED=true
CONTENT_IMPORT_INTERVAL_MS=14400000
CONTENT_IMPORT_TIMEOUT_MS=600000
CONTENT_IMPORT_CITIES=Москва,Санкт-Петербург
CONTENT_IMPORT_SOURCES=kudago,timepad,advcake_ticketland
ADVCAKE_API_PASS=
ADVCAKE_BASE_URL=https://api.advcake.com
ADVCAKE_TICKETLAND_OFFER_ID=663
ADVCAKE_TICKETLAND_WEBSITES=ticketland.ru,live.mts.ru
ADVCAKE_FEED_FORMAT=yml
ENABLE_POSTGIS_EVENT_FEED=false
REDIS_PUBSUB_WARN_PAYLOAD_BYTES=65536
CHAT_WS_MAX_PAYLOAD_BYTES=65536
CHAT_WS_MAX_BUFFERED_BYTES=1048576
CHAT_WS_HEARTBEAT_INTERVAL_MS=30000
CHAT_UNREAD_BACKFILL_BATCH_SIZE=500
CHAT_UNREAD_VERIFY_SAMPLE_SIZE=1000
RETENTION_BATCH_SIZE=500
OUTBOX_DONE_RETENTION_DAYS=14
OUTBOX_FAILED_RETENTION_DAYS=30
AUTH_AUDIT_RETENTION_DAYS=180
OTP_RETENTION_DAYS=7
NOTIFICATION_READ_RETENTION_DAYS=365
PERF_CHECK_USER_ID=
PERF_CHECK_HOST_ID=
PERF_CHECK_LATITUDE=55.75
PERF_CHECK_LONGITUDE=37.61
PERF_CHECK_RADIUS_KM=25
PERF_CHECK_LIMIT=100
PERF_CHECK_INCLUDE_POSTGIS=false
PERF_CHECK_RUN_ANALYZE=false

S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_ACCESS_KEY=tenant-id:key-id
S3_SECRET_KEY=change-me-now
S3_BUCKET=frendly-backet
S3_PUBLIC_ENDPOINT=https://s3.twcstorage.ru
S3_CDN_ENDPOINT=https://cdn.frendly.tech
S3_REQUEST_TIMEOUT_MS=15000

JWT_ACCESS_SECRET=change-me-now
JWT_REFRESH_SECRET=change-me-now
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

PUBLIC_API_URL=https://api.frendly.tech
APP_DEEP_LINK_SCHEME=frendly
