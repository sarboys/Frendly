NODE_ENV=production
CORS_ORIGIN=

POSTGRES_DB=frendly
POSTGRES_USER=frendly
POSTGRES_PASSWORD=change-me-now
DATABASE_DIRECT_URL=postgresql://frendly:change-me-now@postgres:5432/frendly
DATABASE_POOL_URL=postgresql://frendly:change-me-now@pgbouncer:6432/frendly?pgbouncer=true&connection_limit=3&pool_timeout=10
POSTGRES_STATEMENT_TIMEOUT=15s
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
POSTGRES_LOG_MIN_DURATION_STATEMENT=500
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=10
RUN_DB_SEED=false
ENABLE_TESTING_ACCESS=false
CHAT_UNREAD_COUNTER_READS=false
WORKER_OUTBOX_BATCH_CLAIM=false
WORKER_OUTBOX_PROCESSING_CONCURRENCY=1
WORKER_RETENTION_CLEANUP_ENABLED=false
WORKER_RETENTION_CLEANUP_INTERVAL_MS=21600000
ENABLE_POSTGIS_EVENT_FEED=false
CHAT_UNREAD_BACKFILL_BATCH_SIZE=500
CHAT_UNREAD_VERIFY_SAMPLE_SIZE=1000
RETENTION_BATCH_SIZE=500
OUTBOX_DONE_RETENTION_DAYS=14
OUTBOX_FAILED_RETENTION_DAYS=30
AUTH_AUDIT_RETENTION_DAYS=180
OTP_RETENTION_DAYS=7
NOTIFICATION_READ_RETENTION_DAYS=365
PERF_CHECK_USER_ID=
PERF_CHECK_HOST_ID=
PERF_CHECK_LATITUDE=55.75
PERF_CHECK_LONGITUDE=37.61
PERF_CHECK_RADIUS_KM=25
PERF_CHECK_LIMIT=100
PERF_CHECK_INCLUDE_POSTGIS=false
PERF_CHECK_RUN_ANALYZE=false

S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_ACCESS_KEY=tenant-id:key-id
S3_SECRET_KEY=change-me-now
S3_BUCKET=frendly
S3_PUBLIC_ENDPOINT=https://global.s3.cloud.ru

JWT_ACCESS_SECRET=change-me-now
JWT_REFRESH_SECRET=change-me-now
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

TELEGRAM_AUTH_ENABLED=false
TELEGRAM_BOT_USERNAME=
TELEGRAM_POLL_INTERVAL_MS=1500
TELEGRAM_INTERNAL_SECRET=

PUSH_PROVIDER=fake
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
