  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId, id])
  @@index([userId])
  @@index([userId, chatId])
}

model Message {
  id               String              @id @default(cuid())
  chatId           String
  senderId         String
