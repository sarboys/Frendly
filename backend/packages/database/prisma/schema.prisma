  updatedAt        DateTime        @updatedAt
  event            Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eveningSession   EveningSession? @relation(fields: [eveningSessionId], references: [id], onDelete: Cascade)
  createdBy        User            @relation("CreatedPublicShares", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId])
  @@index([eventId])
  @@index([eveningSessionId])
  @@index([createdById, createdAt])
}

model EveningSessionParticipant {
  id        String         @id @default(cuid())
