  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepId, userId])
  @@index([sessionId, stepId, checkedInAt])
  @@index([userId, checkedInAt])
}

model EveningAfterPartyFeedback {
