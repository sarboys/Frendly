  reviewedBy   User?          @relation("ReviewedEveningSessionJoinRequests", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([sessionId, userId])
  @@index([sessionId, status, id])
  @@index([sessionId, status, createdAt, id])
  @@index([userId, status, id])
}

model EveningSessionStepState {
  id         String           @id @default(cuid())
  sessionId  String
  stepId     String
