generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatKind {
  meetup
  direct
  community
}

enum ChatOrigin {
  meetup
  people
  community
}

enum CommunityPrivacy {
  public
  private
}

enum CommunityMemberRole {
  owner
  moderator
  member
}

enum CommunityMediaKind {
  photo
  video
  doc
}

enum MediaAssetKind {
  avatar
  chat_attachment
  chat_voice
  story_media
  poster_cover
}

enum MediaAssetStatus {
  pending
  ready
  failed
}

enum NotificationKind {
  message
  attachment_ready
  event_joined
  event_invite
  event_starting
  like
  subscription_expiring
}

enum PushProvider {
  fcm
  apns
}

enum OutboxStatus {
  pending
  processing
  done
  failed
}

enum EventTone {
  warm
  evening
  sage
}

enum EventJoinMode {
  open
  request
}

enum EventLifestyle {
  zozh
  neutral
  anti
}

enum EventPriceMode {
  free
  fixed
  from
  upto
  range
  split
  host_pays
  fifty_fifty
}

enum DatingActionKind {
  pass
  like
  super_like
}

enum EventAccessMode {
  open
  request
  free
}

enum EventGenderMode {
  all
  male
  female
}

enum UserGender {
  male
  female
}

enum EventVisibilityMode {
  public
  friends
}

enum PosterCategory {
  concert
  sport
  exhibition
  theatre
  standup
  festival
  cinema
}

enum EventJoinRequestStatus {
  pending
  approved
  rejected
  canceled
}

enum AttendanceStatus {
  not_checked_in
  checked_in
  left
}

enum AttendanceCheckInMethod {
  qr
  host_manual
}

enum EventLiveStatus {
  idle
  live
  finished
}

enum TrustedContactMode {
  all_plans
  sos_only
}

enum TrustedContactChannel {
  phone
  telegram
  email
}

enum VerificationStatus {
  not_started
  selfie_submitted
  document_submitted
  under_review
  verified
  rejected
}

enum ReportStatus {
  open
  in_review
  resolved
}

enum SubscriptionPlan {
  month
  year
}

enum SubscriptionStatus {
  inactive
  trial
  active
  canceled
}

enum TelegramLoginSessionStatus {
  pending_bot
  awaiting_contact
  code_issued
  consumed
  failed
}

enum AuthProvider {
  dev
  phone_otp
  session
  telegram
  google
  yandex
}

enum AuthAuditKind {
  start
  verify
  refresh
  logout
}

enum AuthAuditResult {
  issued
  success
  rejected
  conflict
  rate_limited
  revoked
}

model User {
  id                                 String                      @id @default(cuid())
  displayName                        String
  phoneNumber                        String?                     @unique
  email                              String?                     @unique
  verified                           Boolean                     @default(false)
  online                             Boolean                     @default(false)
  createdAt                          DateTime                    @default(now())
  updatedAt                          DateTime                    @updatedAt
  profile                            Profile?
  onboarding                         OnboardingPreferences?
  settings                           UserSettings?
  verification                       UserVerification?
  sessions                           Session[]
  otpChallenges                      PhoneOtpChallenge[]
  pushTokens                         PushToken[]
  notifications                      Notification[]
  hostedEvents                       Event[]                     @relation("HostedEvents")
  eventParticipants                  EventParticipant[]
  joinRequests                       EventJoinRequest[]
  reviewedRequests                   EventJoinRequest[]          @relation("ReviewedJoinRequests")
  eventAttendances                   EventAttendance[]           @relation("EventAttendanceUser")
  checkedInEvents                    EventAttendance[]           @relation("AttendanceCheckedInBy")
  feedbacks                          EventFeedback[]
  favoriteSources                    EventFavorite[]             @relation("EventFavoriteSource")
  favoriteTargets                    EventFavorite[]             @relation("EventFavoriteTarget")
  trustedContacts                    TrustedContact[]
  safetySosAlerts                    SafetySosAlert[]
  reportsSent                        UserReport[]                @relation("UserReportsSent")
  reportsReceived                    UserReport[]                @relation("UserReportsReceived")
  createdPublicShares                PublicShare[]               @relation("CreatedPublicShares")
  blockedUsers                       UserBlock[]                 @relation("UserBlocks")
  blockedByUsers                     UserBlock[]                 @relation("BlockedByUsers")
  stories                            EventStory[]
  subscriptions                      UserSubscription[]
  chatMembers                        ChatMember[]
  createdCommunities                 Community[]                 @relation("CommunityCreator")
  communityMemberships               CommunityMember[]
  messages                           Message[]
  mediaAssets                        MediaAsset[]
  telegramAccount                    TelegramAccount?
  externalAuthAccounts               ExternalAuthAccount[]
  authAuditEvents                    AuthAuditEvent[]
  datingActionsSent                  DatingAction[]              @relation("DatingActionActor")
  datingActionsReceived              DatingAction[]              @relation("DatingActionTarget")
  eveningStepActions                 UserEveningStepAction[]
  hostedEveningSessions              EveningSession[]            @relation("EveningSessionHost")
  eveningSessionParticipants         EveningSessionParticipant[]
  eveningSessionJoinRequests         EveningSessionJoinRequest[]
  reviewedEveningSessionJoinRequests EveningSessionJoinRequest[] @relation("ReviewedEveningSessionJoinRequests")
  eveningStepCheckIns                EveningStepCheckIn[]
  eveningAfterPartyFeedbacks         EveningAfterPartyFeedback[]
  eveningAfterPartyPhotos            EveningAfterPartyPhoto[]
  partnerOfferCodes                  PartnerOfferCode[]

  @@index([displayName, id])
}

model UserSettings {
  userId                  String    @id
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowLocation           Boolean   @default(true)
  allowPush               Boolean   @default(true)
  allowContacts           Boolean   @default(false)
  autoSharePlans          Boolean   @default(true)
  hideExactLocation       Boolean   @default(false)
  quietHours              Boolean   @default(false)
  showAge                 Boolean   @default(true)
  discoverable            Boolean   @default(true)
  darkMode                Boolean   @default(false)
  afterDarkAgeConfirmedAt DateTime?
  afterDarkCodeAcceptedAt DateTime?
  updatedAt               DateTime  @updatedAt

  @@index([discoverable, userId])
}

model UserVerification {
  userId       String             @id
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       VerificationStatus @default(not_started)
  selfieDone   Boolean            @default(false)
  documentDone Boolean            @default(false)
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model PhoneOtpChallenge {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneNumber    String
  codeHash       String
  codeSalt       String
  requestKeyHash String?
  attemptCount   Int       @default(0)
  lastAttemptAt  DateTime?
  lastIssuedAt   DateTime?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([phoneNumber, consumedAt, expiresAt])
  @@index([requestKeyHash, createdAt])
}

model TelegramAccount {
  userId         String    @id
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramUserId String    @unique
  chatId         String
  username       String?
  firstName      String?
  lastName       String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ExternalAuthAccount {
  id             String       @id @default(cuid())
  provider       AuthProvider
  providerUserId String
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  email          String?
  displayName    String?
  avatarUrl      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model TelegramLoginSession {
  id               String                     @id @default(cuid())
  loginSessionId   String                     @unique
  startToken       String                     @unique
  status           TelegramLoginSessionStatus @default(pending_bot)
  telegramUserId   String?
  chatId           String?
  username         String?
  firstName        String?
  lastName         String?
  phoneNumber      String?
  codeSalt         String?
  codeHash         String?
  codeLookup       String?
  attemptCount     Int                        @default(0)
  expiresAt        DateTime
  consumedAt       DateTime?
  lastCodeIssuedAt DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([status, expiresAt])
  @@index([telegramUserId, status])
  @@index([codeLookup, status, expiresAt])
}

model AuthAuditEvent {
  id             String          @id @default(cuid())
  provider       AuthProvider
  kind           AuthAuditKind
  result         AuthAuditResult
  requestId      String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  telegramUserId String?
  loginSessionId String?
  sessionId      String?
  maskedPhone    String?
  ip             String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([provider, kind, createdAt])
  @@index([loginSessionId, createdAt])
  @@index([telegramUserId, createdAt])
  @@index([userId, createdAt])
}

model Profile {
  userId        String         @id
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  age           Int?
  birthDate     DateTime?      @db.Date
  gender        UserGender?
  city          String?
  area          String?
  bio           String?
  vibe          String?
  rating        Float          @default(0)
  meetupCount   Int            @default(0)
  avatarUrl     String?
  avatarAssetId String?        @unique
  avatarAsset   MediaAsset?    @relation("ProfileAvatar", fields: [avatarAssetId], references: [id])
  photos        ProfilePhoto[]
  updatedAt     DateTime       @updatedAt
}

model ProfilePhoto {
  id            String     @id @default(cuid())
  profileUserId String
  profile       Profile    @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)
  mediaAssetId  String     @unique
  mediaAsset    MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  sortOrder     Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([profileUserId, sortOrder])
}

model OnboardingPreferences {
  userId    String      @id
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  intent    String?
  gender    UserGender?
  birthDate DateTime?   @db.Date
  city      String?
  area      String?
  interests Json
  vibe      String?
  updatedAt DateTime    @updatedAt
}

model Session {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenId String       @unique
  provider       AuthProvider @default(session)
  createdAt      DateTime     @default(now())
  lastUsedAt     DateTime?
  revokedAt      DateTime?
}

model Event {
  id                String              @id @default(cuid())
  title             String
  emoji             String
  startsAt          DateTime
  durationMinutes   Int                 @default(120)
  place             String
  distanceKm        Float
  latitude          Float?
  longitude         Float?
  vibe              String
  tone              EventTone           @default(warm)
  joinMode          EventJoinMode       @default(open)
  lifestyle         EventLifestyle      @default(neutral)
  priceMode         EventPriceMode      @default(free)
  priceAmountFrom   Int?
  priceAmountTo     Int?
  accessMode        EventAccessMode     @default(open)
  genderMode        EventGenderMode     @default(all)
  visibilityMode    EventVisibilityMode @default(public)
  hostNote          String?
  description       String
  partnerName       String?
  partnerOffer      String?
  isAfterDark       Boolean             @default(false)
  afterDarkCategory String?
  afterDarkGlow     String?
  dressCode         String?
  ageRange          String?
  ratioLabel        String?
  consentRequired   Boolean             @default(false)
  rules             Json?
  capacity          Int
  idempotencyKey    String?
  isCalm            Boolean             @default(false)
  isNewcomers       Boolean             @default(false)
  isDate            Boolean             @default(false)
  sourcePosterId    String?
  hostId            String
  host              User                @relation("HostedEvents", fields: [hostId], references: [id])
  sourcePoster      Poster?             @relation(fields: [sourcePosterId], references: [id], onDelete: SetNull)
  participants      EventParticipant[]
  joinRequests      EventJoinRequest[]
  attendances       EventAttendance[]
  liveState         EventLiveState?
  feedbacks         EventFeedback[]
  favorites         EventFavorite[]
  stories           EventStory[]
  publicShares      PublicShare[]
  safetySosAlerts   SafetySosAlert[]
  chat              Chat?
  sourceChats       Chat[]              @relation("ChatSourceEvent")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([hostId, idempotencyKey])
  @@index([sourcePosterId])
  @@index([isAfterDark, startsAt])
  @@index([isAfterDark, startsAt, id])
  @@index([isAfterDark, distanceKm, id])
  @@index([isAfterDark, isCalm, startsAt, id])
  @@index([isAfterDark, isNewcomers, startsAt, id])
  @@index([isAfterDark, isDate, startsAt, id])
  @@index([isAfterDark, lifestyle, startsAt, id])
  @@index([isAfterDark, priceMode, startsAt, id])
  @@index([isAfterDark, accessMode, startsAt, id])
  @@index([isAfterDark, genderMode, startsAt, id])
  @@index([startsAt, id])
  @@index([hostId, startsAt, id])
}

model Poster {
  id           String         @id
  city         String
  category     PosterCategory
  title        String
  emoji        String
  startsAt     DateTime
  dateLabel    String
  timeLabel    String
  venue        String
  address      String
  distanceKm   Float
  priceFrom    Int
  ticketUrl    String
  provider     String
  tone         EventTone      @default(warm)
  tags         Json
  description  String
  isFeatured   Boolean        @default(false)
  coverAssetId String?        @unique
  events       Event[]
  coverAsset   MediaAsset?    @relation(fields: [coverAssetId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([city, startsAt])
  @@index([city, category, startsAt])
  @@index([city, isFeatured, startsAt])
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  city      String
  status    String   @default("active")
  contact   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venues     Venue[]
  offers     PartnerOffer[]
  offerCodes PartnerOfferCode[]

  @@index([city, status, id])
}

model Venue {
  id                String    @id @default(cuid())
  ownerType         String    @default("frendly")
  partnerId         String?
  source            String    @default("manual")
  externalId        String?
  moderationStatus  String    @default("approved")
  trustLevel        String    @default("verified")
  city              String
  timezone          String    @default("Europe/Moscow")
  area              String?
  name              String
  address           String
  lat               Float
  lng               Float
  category          String
  tags              Json
  averageCheck      Int?
  openingHours      Json?
  status            String    @default("open")
  lastSyncedAt      DateTime?
  lastVerifiedAt    DateTime?
  verifiedByAdminId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  partner    Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  offers     PartnerOffer[]
  routeSteps EveningRouteStep[]
  offerCodes PartnerOfferCode[]

  @@unique([source, externalId])
  @@index([city, moderationStatus, trustLevel, id])
  @@index([city, category, id])
  @@index([partnerId, id])
}

model PartnerOffer {
  id          String    @id @default(cuid())
  partnerId   String
  venueId     String
  title       String
  description String
  terms       String?
  shortLabel  String?
  validFrom   DateTime?
  validTo     DateTime?
  daysOfWeek  Json?
  timeWindow  Json?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  partner    Partner            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  venue      Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  routeSteps EveningRouteStep[]
  codes      PartnerOfferCode[]

  @@index([partnerId, status, id])
  @@index([venueId, status, id])
}

model PartnerOfferCode {
  id                 String    @id @default(cuid())
  codeHash           String    @unique
  userId             String
  sessionId          String
  routeId            String
  routeTemplateId    String?
  stepId             String
  partnerId          String
  venueId            String
  offerId            String
  status             String    @default("issued")
  issuedAt           DateTime  @default(now())
  activatedAt        DateTime?
  expiresAt          DateTime
  activatedIpHash    String?
  activatedUserAgent String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session EveningSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  route   EveningRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  step    EveningRouteStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  partner Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  venue   Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  offer   PartnerOffer     @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId, partnerId, stepId, offerId])
  @@index([sessionId, userId, status])
  @@index([partnerId, activatedAt, id])
  @@index([venueId, activatedAt, id])
  @@index([offerId, activatedAt, id])
  @@index([routeTemplateId, activatedAt, id])
}

model AiEveningBrief {
  id               String   @id @default(cuid())
  city             String
  timezone         String   @default("Europe/Moscow")
  area             String?
  titleIdea        String
  audience         String
  format           String
  mood             String
  budget           String
  durationMinutes  Int
  minSteps         Int      @default(2)
  maxSteps         Int      @default(4)
  requiredVenueIds Json?
  excludedVenueIds Json?
  partnerGoal      String?
  tone             String?
  boldness         String?
  status           String   @default("draft")
  createdByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  runs   AiEveningGenerationRun[]
  drafts AiEveningDraft[]

  @@index([city, status, createdAt, id])
}

model AiEveningGenerationRun {
  id            String    @id @default(cuid())
  briefId       String
  provider      String    @default("openrouter")
  model         String
  promptVersion String
  status        String    @default("running")
  requestJson   Json
  responseJson  Json?
  errorCode     String?
  errorMessage  String?
  latencyMs     Int?
  createdAt     DateTime  @default(now())
  finishedAt    DateTime?

  brief  AiEveningBrief   @relation(fields: [briefId], references: [id], onDelete: Cascade)
  drafts AiEveningDraft[]

  @@index([briefId, createdAt, id])
  @@index([provider, model, createdAt, id])
}

model AiEveningDraft {
  id               String    @id @default(cuid())
  briefId          String
  runId            String?
  title            String
  description      String
  city             String
  area             String?
  vibe             String
  budget           String
  durationLabel    String
  totalPriceFrom   Int
  score            Int       @default(0)
  validationStatus String    @default("pending")
  validationIssues Json?
  selectedAt       DateTime?
  createdRouteId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  brief AiEveningBrief          @relation(fields: [briefId], references: [id], onDelete: Cascade)
  run   AiEveningGenerationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  steps AiEveningDraftStep[]

  @@index([briefId, validationStatus, score, id])
}

model AiEveningDraftStep {
  id             String   @id @default(cuid())
  draftId        String
  sortOrder      Int
  venueId        String?
  partnerOfferId String?
  kind           String
  title          String
  timeLabel      String
  endTimeLabel   String?
  description    String?
  transition     String?
  priceEstimate  Int?
  walkMin        Int?
  createdAt      DateTime @default(now())

  draft AiEveningDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId, sortOrder, id])
  @@index([venueId])
}

model EveningRouteTemplate {
  id                 String    @id @default(cuid())
  source             String    @default("team")
  status             String    @default("draft")
  city               String
  timezone           String    @default("Europe/Moscow")
  area               String?
  centerLat          Float?
  centerLng          Float?
  radiusMeters       Int?
  currentRouteId     String?   @unique
  scheduledPublishAt DateTime?
  publishedAt        DateTime?
  archivedAt         DateTime?
  createdByAdminId   String?
  updatedByAdminId   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  currentRoute EveningRoute?    @relation("CurrentEveningRoute", fields: [currentRouteId], references: [id], onDelete: SetNull)
  revisions    EveningRoute[]   @relation("EveningRouteTemplateRevisions")
  sessions     EveningSession[]

  @@index([city, status, publishedAt, id])
  @@index([city, scheduledPublishAt, id])
}

model EveningRoute {
  id                 String                  @id
  templateId         String?
  title              String
  vibe               String
  blurb              String
  totalPriceFrom     Int
  totalSavings       Int
  durationLabel      String
  area               String
  goal               String
  mood               String
  budget             String
  format             String?
  premium            Boolean                 @default(false)
  recommendedFor     String?
  hostsCount         Int                     @default(0)
  chatId             String?                 @unique
  version            Int                     @default(1)
  source             String                  @default("manual")
  status             String                  @default("legacy")
  city               String                  @default("Москва")
  timezone           String                  @default("Europe/Moscow")
  centerLat          Float?
  centerLng          Float?
  radiusMeters       Int?
  isCurated          Boolean                 @default(false)
  badgeLabel         String?
  coverAssetId       String?
  createdByAdminId   String?
  publishedAt        DateTime?
  archivedAt         DateTime?
  template           EveningRouteTemplate?   @relation("EveningRouteTemplateRevisions", fields: [templateId], references: [id], onDelete: SetNull)
  currentForTemplate EveningRouteTemplate?   @relation("CurrentEveningRoute")
  chat               Chat?                   @relation("EveningRouteChat", fields: [chatId], references: [id], onDelete: SetNull)
  steps              EveningRouteStep[]
  stepActions        UserEveningStepAction[]
  sessions           EveningSession[]
  partnerOfferCodes  PartnerOfferCode[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([goal, mood, budget, id])
  @@index([premium, id])
  @@index([templateId, version])
  @@index([city, status, isCurated, id])
  @@index([city, publishedAt, id])
}

model EveningRouteStep {
  id                       String                    @id
  routeId                  String
  route                    EveningRoute              @relation(fields: [routeId], references: [id], onDelete: Cascade)
  venueId                  String?
  partnerOfferId           String?
  sortOrder                Int
  timeLabel                String
  endTimeLabel             String?
  kind                     String
  title                    String
  venue                    String
  address                  String
  emoji                    String
  distanceLabel            String
  walkMin                  Int?
  perk                     String?
  perkShort                String?
  ticketPrice              Int?
  ticketCommission         Int?
  sponsored                Boolean                   @default(false)
  premium                  Boolean                   @default(false)
  partnerId                String?
  description              String?
  vibeTag                  String?
  lat                      Float
  lng                      Float
  offerTitleSnapshot       String?
  offerDescriptionSnapshot String?
  offerTermsSnapshot       String?
  offerShortLabelSnapshot  String?
  offerValidFromSnapshot   DateTime?
  offerValidToSnapshot     DateTime?
  venueNameSnapshot        String?
  venueAddressSnapshot     String?
  venueLatSnapshot         Float?
  venueLngSnapshot         Float?
  venueRecord              Venue?                    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  partnerOffer             PartnerOffer?             @relation(fields: [partnerOfferId], references: [id], onDelete: SetNull)
  actions                  UserEveningStepAction[]
  sessionStates            EveningSessionStepState[]
  checkIns                 EveningStepCheckIn[]
  partnerOfferCodes        PartnerOfferCode[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([routeId, sortOrder, id])
  @@index([venueId])
  @@index([partnerOfferId])
}

model UserEveningStepAction {
  id             String           @id @default(cuid())
  userId         String
  routeId        String
  stepId         String
  perkUsedAt     DateTime?
  ticketBoughtAt DateTime?
  sentToChatAt   DateTime?
  chatMessageId  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  route          EveningRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  step           EveningRouteStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
  @@index([userId, routeId])
  @@index([routeId, stepId])
}

model EveningSession {
  id                  String                      @id @default(cuid())
  routeId             String
  routeTemplateId     String?
  hostUserId          String
  chatId              String                      @unique
  phase               String                      @default("scheduled")
  privacy             String                      @default("open")
  mode                String                      @default("hybrid")
  capacity            Int                         @default(10)
  startsAt            DateTime?
  startedAt           DateTime?
  endedAt             DateTime?
  currentStep         Int?
  inviteToken         String?                     @unique
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  route               EveningRoute                @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeTemplate       EveningRouteTemplate?       @relation(fields: [routeTemplateId], references: [id], onDelete: SetNull)
  host                User                        @relation("EveningSessionHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  chat                Chat                        @relation("EveningSessionChat", fields: [chatId], references: [id], onDelete: Cascade)
  participants        EveningSessionParticipant[]
  joinRequests        EveningSessionJoinRequest[]
  stepStates          EveningSessionStepState[]
  checkIns            EveningStepCheckIn[]
  afterPartyFeedbacks EveningAfterPartyFeedback[]
  afterPartyPhotos    EveningAfterPartyPhoto[]
  publicShares        PublicShare[]
  partnerOfferCodes   PartnerOfferCode[]

  @@index([phase, startsAt, id])
  @@index([hostUserId, phase, id])
  @@index([routeId, createdAt, id])
  @@index([routeTemplateId, phase, startsAt, id])
  @@index([chatId])
}

model PublicShare {
  id               String          @id @default(cuid())
