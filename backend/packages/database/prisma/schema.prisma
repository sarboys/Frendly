model Chat {
  id             String          @id @default(cuid())
  kind           ChatKind
  origin         ChatOrigin
  title          String?
  emoji          String?
  eventId        String?         @unique
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sourceEventId  String?
  sourceEvent    Event?          @relation("ChatSourceEvent", fields: [sourceEventId], references: [id], onDelete: SetNull)
  directKey      String?         @unique
  meetupPhase    String          @default("upcoming")
  meetupMode     String          @default("hybrid")
  currentStep    Int?
  meetupStartsAt DateTime?
  meetupEndsAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       Message[]
  members        ChatMember[]
  community      Community?
  eveningRoute   EveningRoute?   @relation("EveningRouteChat")
  eveningSession EveningSession? @relation("EveningSessionChat")
  realtimeEvents RealtimeEvent[]

  @@index([kind, updatedAt, id])
  @@index([kind, meetupPhase, updatedAt, id])
}

model ChatMember {
