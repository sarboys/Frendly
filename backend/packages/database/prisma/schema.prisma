  step       EveningRouteStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepId])
  @@index([sessionId, status, id])
  @@index([stepId])
}

model EveningStepCheckIn {
  id          String           @id @default(cuid())
  sessionId   String
  stepId      String
  userId      String
