generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatKind {
  meetup
  direct
  community
}

enum ChatOrigin {
  meetup
  people
  community
}

enum CommunityPrivacy {
  public
  private
}

enum CommunityMemberRole {
  owner
  moderator
  member
}

enum CommunityMediaKind {
  photo
  video
  doc
}

enum MediaAssetKind {
  avatar
  chat_attachment
  chat_voice
  story_media
  poster_cover
}

enum MediaAssetStatus {
  pending
  ready
  failed
}

enum NotificationKind {
  message
  attachment_ready
  event_joined
  event_invite
  event_starting
  like
  subscription_expiring
}

enum PushProvider {
  fcm
  apns
}

enum OutboxStatus {
  pending
  processing
  done
  failed
}

enum EventTone {
  warm
  evening
  sage
}

enum EventJoinMode {
  open
  request
}

enum EventLifestyle {
  zozh
  neutral
  anti
}

enum EventPriceMode {
  free
  fixed
  from
  upto
  range
  split
  host_pays
  fifty_fifty
}

enum DatingActionKind {
  pass
  like
  super_like
}

enum EventAccessMode {
  open
  request
  free
}

enum EventGenderMode {
  all
  male
  female
}

enum UserGender {
  male
  female
}

enum EventVisibilityMode {
  public
  friends
}

enum PosterCategory {
  concert
  sport
  exhibition
  theatre
  standup
  festival
  cinema
}

enum EventJoinRequestStatus {
  pending
  approved
  rejected
  canceled
}

enum AttendanceStatus {
  not_checked_in
  checked_in
  left
}

enum AttendanceCheckInMethod {
  qr
  host_manual
}

enum EventLiveStatus {
  idle
  live
  finished
}

enum TrustedContactMode {
  all_plans
  sos_only
}

enum VerificationStatus {
  not_started
  selfie_submitted
  document_submitted
  under_review
  verified
  rejected
}

enum ReportStatus {
  open
  in_review
  resolved
}

enum SubscriptionPlan {
  month
  year
}

enum SubscriptionStatus {
  inactive
  trial
  active
  canceled
}

enum TelegramLoginSessionStatus {
  pending_bot
  awaiting_contact
  code_issued
  consumed
  failed
}

enum AuthProvider {
  dev
  phone_otp
  telegram
}

enum AuthAuditKind {
  start
  verify
  refresh
  logout
}

enum AuthAuditResult {
  issued
  success
  rejected
  conflict
  rate_limited
  revoked
}

model User {
  id                String                  @id @default(cuid())
  displayName       String
  phoneNumber       String?                 @unique
  verified          Boolean                 @default(false)
  online            Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  profile           Profile?
  onboarding        OnboardingPreferences?
  settings          UserSettings?
  verification      UserVerification?
  sessions          Session[]
  otpChallenges     PhoneOtpChallenge[]
  pushTokens        PushToken[]
  notifications     Notification[]
  hostedEvents      Event[]                 @relation("HostedEvents")
  eventParticipants EventParticipant[]
  joinRequests      EventJoinRequest[]
  reviewedRequests  EventJoinRequest[]      @relation("ReviewedJoinRequests")
  eventAttendances  EventAttendance[]       @relation("EventAttendanceUser")
  checkedInEvents   EventAttendance[]       @relation("AttendanceCheckedInBy")
  feedbacks         EventFeedback[]
  favoriteSources   EventFavorite[]         @relation("EventFavoriteSource")
  favoriteTargets   EventFavorite[]         @relation("EventFavoriteTarget")
  trustedContacts   TrustedContact[]
  reportsSent       UserReport[]            @relation("UserReportsSent")
  reportsReceived   UserReport[]            @relation("UserReportsReceived")
  blockedUsers      UserBlock[]             @relation("UserBlocks")
  blockedByUsers    UserBlock[]             @relation("BlockedByUsers")
  stories           EventStory[]
  subscriptions     UserSubscription[]
  chatMembers       ChatMember[]
  createdCommunities Community[]             @relation("CommunityCreator")
  communityMemberships CommunityMember[]
  messages          Message[]
  mediaAssets       MediaAsset[]
  telegramAccount   TelegramAccount?
  authAuditEvents   AuthAuditEvent[]
  datingActionsSent DatingAction[]          @relation("DatingActionActor")
  datingActionsReceived DatingAction[]       @relation("DatingActionTarget")
  eveningStepActions UserEveningStepAction[]

  @@index([displayName, id])
}

model UserSettings {
  userId              String   @id
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowLocation       Boolean  @default(true)
  allowPush           Boolean  @default(true)
  allowContacts       Boolean  @default(false)
  autoSharePlans      Boolean  @default(true)
  hideExactLocation   Boolean  @default(false)
  quietHours          Boolean  @default(false)
  showAge             Boolean  @default(true)
  discoverable        Boolean  @default(true)
  darkMode            Boolean  @default(false)
  afterDarkAgeConfirmedAt DateTime?
  afterDarkCodeAcceptedAt DateTime?
  updatedAt           DateTime @updatedAt

  @@index([discoverable, userId])
}

model UserVerification {
  userId        String             @id
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        VerificationStatus @default(not_started)
  selfieDone    Boolean            @default(false)
  documentDone  Boolean            @default(false)
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model PhoneOtpChallenge {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  phoneNumber  String
  code         String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([phoneNumber, createdAt])
}

model TelegramAccount {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramUserId  String   @unique
  chatId          String
  username        String?
  firstName       String?
  lastName        String?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TelegramLoginSession {
  id               String                     @id @default(cuid())
  loginSessionId   String                     @unique
  startToken       String                     @unique
  status           TelegramLoginSessionStatus @default(pending_bot)
  telegramUserId   String?
  chatId           String?
  username         String?
  firstName        String?
  lastName         String?
  phoneNumber      String?
  codeSalt         String?
  codeHash         String?
  codeLookup       String?
  attemptCount     Int                        @default(0)
  expiresAt        DateTime
  consumedAt       DateTime?
  lastCodeIssuedAt DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([status, expiresAt])
  @@index([telegramUserId, status])
  @@index([codeLookup, status, expiresAt])
}

model AuthAuditEvent {
  id             String          @id @default(cuid())
  provider       AuthProvider
  kind           AuthAuditKind
  result         AuthAuditResult
  requestId      String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  telegramUserId String?
  loginSessionId String?
  sessionId      String?
  maskedPhone    String?
  ip             String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([provider, kind, createdAt])
  @@index([loginSessionId, createdAt])
  @@index([telegramUserId, createdAt])
  @@index([userId, createdAt])
}

model Profile {
  userId         String      @id
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  age            Int?
  birthDate      DateTime?   @db.Date
  gender         UserGender?
  city           String?
  area           String?
  bio            String?
  vibe           String?
  rating         Float       @default(0)
  meetupCount    Int         @default(0)
  avatarUrl      String?
  avatarAssetId  String?     @unique
  avatarAsset    MediaAsset? @relation("ProfileAvatar", fields: [avatarAssetId], references: [id])
  photos         ProfilePhoto[]
  updatedAt      DateTime    @updatedAt
}

model ProfilePhoto {
  id            String     @id @default(cuid())
  profileUserId String
  profile       Profile    @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)
  mediaAssetId  String     @unique
  mediaAsset    MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  sortOrder     Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([profileUserId, sortOrder])
}

model OnboardingPreferences {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  intent     String?
  gender     UserGender?
  birthDate  DateTime? @db.Date
  city       String?
  area       String?
  interests  Json
  vibe       String?
  updatedAt  DateTime @updatedAt
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenId String    @unique
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  revokedAt      DateTime?
}

model Event {
  id              String             @id @default(cuid())
  title           String
  emoji           String
  startsAt        DateTime
  durationMinutes Int                @default(120)
  place           String
  distanceKm      Float
  latitude        Float?
  longitude       Float?
  vibe            String
  tone            EventTone          @default(warm)
  joinMode        EventJoinMode      @default(open)
  lifestyle       EventLifestyle     @default(neutral)
  priceMode       EventPriceMode     @default(free)
  priceAmountFrom Int?
  priceAmountTo   Int?
  accessMode      EventAccessMode    @default(open)
  genderMode      EventGenderMode    @default(all)
  visibilityMode  EventVisibilityMode @default(public)
  hostNote        String?
  description     String
  partnerName     String?
  partnerOffer    String?
  isAfterDark     Boolean            @default(false)
  afterDarkCategory String?
  afterDarkGlow   String?
  dressCode       String?
  ageRange        String?
  ratioLabel      String?
  consentRequired Boolean            @default(false)
  rules           Json?
  capacity        Int
  idempotencyKey  String?
  isCalm          Boolean            @default(false)
  isNewcomers     Boolean            @default(false)
  isDate          Boolean            @default(false)
  sourcePosterId  String?
  hostId          String
  host            User               @relation("HostedEvents", fields: [hostId], references: [id])
  sourcePoster    Poster?            @relation(fields: [sourcePosterId], references: [id], onDelete: SetNull)
  participants    EventParticipant[]
  joinRequests    EventJoinRequest[]
  attendances     EventAttendance[]
  liveState       EventLiveState?
  feedbacks       EventFeedback[]
  favorites       EventFavorite[]
  stories         EventStory[]
  chat            Chat?
  sourceChats     Chat[]             @relation("ChatSourceEvent")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([sourcePosterId])
  @@index([isAfterDark, startsAt])
  @@index([isAfterDark, startsAt, id])
  @@index([isAfterDark, distanceKm, id])
  @@index([isAfterDark, isCalm, startsAt, id])
  @@index([isAfterDark, isNewcomers, startsAt, id])
  @@index([isAfterDark, isDate, startsAt, id])
  @@index([isAfterDark, lifestyle, startsAt, id])
  @@index([isAfterDark, priceMode, startsAt, id])
  @@index([isAfterDark, accessMode, startsAt, id])
  @@index([isAfterDark, genderMode, startsAt, id])
  @@index([startsAt, id])
  @@index([hostId, startsAt, id])
  @@unique([hostId, idempotencyKey])
}

model Poster {
  id          String         @id
  city        String
  category    PosterCategory
  title       String
  emoji       String
  startsAt    DateTime
  dateLabel   String
  timeLabel   String
  venue       String
  address     String
  distanceKm  Float
  priceFrom   Int
  ticketUrl   String
  provider    String
  tone        EventTone      @default(warm)
  tags        Json
  description String
  isFeatured  Boolean        @default(false)
  coverAssetId String?       @unique
  events      Event[]
  coverAsset  MediaAsset?    @relation(fields: [coverAssetId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([city, startsAt])
  @@index([city, category, startsAt])
  @@index([city, isFeatured, startsAt])
}

model EveningRoute {
  id             String                  @id
  title          String
  vibe           String
  blurb          String
  totalPriceFrom Int
  totalSavings   Int
  durationLabel  String
  area           String
  goal           String
  mood           String
  budget         String
  format         String?
  premium        Boolean                 @default(false)
  recommendedFor String?
  hostsCount     Int                     @default(0)
  chatId         String?                 @unique
  chat           Chat?                   @relation("EveningRouteChat", fields: [chatId], references: [id], onDelete: SetNull)
  steps          EveningRouteStep[]
  stepActions    UserEveningStepAction[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([goal, mood, budget, id])
  @@index([premium, id])
}

model EveningRouteStep {
  id               String                  @id
  routeId          String
  route            EveningRoute            @relation(fields: [routeId], references: [id], onDelete: Cascade)
  sortOrder        Int
  timeLabel        String
  endTimeLabel     String?
  kind             String
  title            String
  venue            String
  address          String
  emoji            String
  distanceLabel    String
  walkMin          Int?
  perk             String?
  perkShort        String?
  ticketPrice      Int?
  ticketCommission Int?
  sponsored        Boolean                 @default(false)
  premium          Boolean                 @default(false)
  partnerId        String?
  description      String?
  vibeTag          String?
  lat              Float
  lng              Float
  actions          UserEveningStepAction[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([routeId, sortOrder, id])
}

model UserEveningStepAction {
  id              String           @id @default(cuid())
  userId          String
  routeId         String
  stepId          String
  perkUsedAt      DateTime?
  ticketBoughtAt  DateTime?
  sentToChatAt    DateTime?
  chatMessageId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  route           EveningRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  step            EveningRouteStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
  @@index([userId, routeId])
  @@index([routeId, stepId])
}

model EventParticipant {
  id        String   @id @default(cuid())
  eventId    String
  userId     String
  joinedAt   DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, joinedAt, id])
}

model EventJoinRequest {
  id                 String                 @id @default(cuid())
  eventId            String
  userId             String
  note               String?
  status             EventJoinRequestStatus @default(pending)
  compatibilityScore Int                    @default(0)
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  event              Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy         User?                  @relation("ReviewedJoinRequests", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@index([status, reviewedById, createdAt, id])
  @@index([eventId, status, reviewedById, createdAt, id])
}

model EventAttendance {
  id              String                 @id @default(cuid())
  eventId         String
  userId          String
  status          AttendanceStatus       @default(not_checked_in)
  checkedInAt     DateTime?
  checkedInById   String?
  checkInMethod   AttendanceCheckInMethod?
  leftAt          DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  event           Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User                   @relation("EventAttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  checkedInBy     User?                  @relation("AttendanceCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([eventId, status])
}

model EventLiveState {
  id         String          @id @default(cuid())
  eventId     String          @unique
  status      EventLiveStatus @default(idle)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventFeedback {
  id         String   @id @default(cuid())
  eventId     String
  userId      String
  vibe        String
  hostRating  Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventFavorite {
  id            String   @id @default(cuid())
  eventId        String
  sourceUserId   String
  targetUserId   String
  createdAt      DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sourceUser     User     @relation("EventFavoriteSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetUser     User     @relation("EventFavoriteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, sourceUserId, targetUserId])
  @@index([sourceUserId, targetUserId])
  @@index([targetUserId, sourceUserId])
}

model TrustedContact {
  id          String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phoneNumber  String
  mode         TrustedContactMode @default(all_plans)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, createdAt, id])
  @@index([userId, phoneNumber])
}

model UserReport {
  id            String       @id @default(cuid())
  reporterId     String
  targetUserId   String
  reason         String
  details        String?
  status         ReportStatus @default(open)
  blockRequested Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  reporter       User         @relation("UserReportsSent", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser     User         @relation("UserReportsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([reporterId, status, createdAt, id])
  @@index([targetUserId, status, createdAt, id])
}

model UserBlock {
  id            String   @id @default(cuid())
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())
  user          User     @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedByUsers", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([blockedUserId, userId])
}

model EventStory {
  id         String   @id @default(cuid())
  eventId     String
  authorId    String
  caption     String
  emoji       String
  mediaAssetId String? @unique
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
}

model UserSubscription {
  id          String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan
  status       SubscriptionStatus @default(inactive)
  startedAt    DateTime?
  renewsAt     DateTime?
  trialEndsAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status, renewsAt])
  @@index([userId, status, trialEndsAt])
  @@index([status, renewsAt, id])
  @@index([status, trialEndsAt, id])
}

model DatingAction {
  id           String           @id @default(cuid())
  actorUserId  String
  targetUserId String
  action       DatingActionKind
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  actorUser    User             @relation("DatingActionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser   User             @relation("DatingActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([actorUserId, targetUserId])
  @@index([targetUserId, action, createdAt])
  @@index([actorUserId, action, createdAt])
}

model Community {
  id               String                 @id @default(cuid())
  name             String
  avatar           String
  description      String
  privacy          CommunityPrivacy       @default(public)
  tags             Json
  joinRule         String
  premiumOnly      Boolean                @default(true)
  mood             String
  sharedMediaLabel String
  createdById      String
  chatId           String                 @unique
  idempotencyKey   String?
  createdBy        User                   @relation("CommunityCreator", fields: [createdById], references: [id], onDelete: Cascade)
  chat             Chat                   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  members          CommunityMember[]
  news             CommunityNewsItem[]
  meetups          CommunityMeetupItem[]
  media            CommunityMediaItem[]
  socialLinks      CommunitySocialLink[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([createdAt, id])
  @@index([privacy, createdAt, id])
  @@unique([createdById, idempotencyKey])
}

model CommunityMember {
  id          String              @id @default(cuid())
  communityId String
  userId      String
  role        CommunityMemberRole @default(member)
  joinedAt    DateTime            @default(now())
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId, joinedAt])
  @@index([communityId, joinedAt, id])
}

model CommunityNewsItem {
  id          String    @id @default(cuid())
  communityId String
  title       String
  blurb       String
  timeLabel   String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, sortOrder, id])
}

model CommunityMeetupItem {
  id          String    @id @default(cuid())
  communityId String
  title       String
  emoji       String
  timeLabel   String
  place       String
  format      String
  going       Int       @default(0)
  sortOrder   Int       @default(0)
  startsAt    DateTime?
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, sortOrder, id])
}

model CommunityMediaItem {
  id          String             @id @default(cuid())
  communityId String
  emoji       String
  label       String
  kind        CommunityMediaKind
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, sortOrder, id])
}

model CommunitySocialLink {
  id          String    @id @default(cuid())
  communityId String
  label       String
  handle      String
  sortOrder   Int       @default(0)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, sortOrder, id])
}

model Chat {
  id             String          @id @default(cuid())
  kind           ChatKind
  origin         ChatOrigin
  title          String?
  emoji          String?
  eventId        String?         @unique
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sourceEventId  String?
  sourceEvent    Event?          @relation("ChatSourceEvent", fields: [sourceEventId], references: [id], onDelete: SetNull)
  directKey      String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       Message[]
  members        ChatMember[]
  community      Community?
  eveningRoute   EveningRoute?  @relation("EveningRouteChat")
  realtimeEvents RealtimeEvent[]

  @@index([kind, updatedAt, id])
}

model ChatMember {
  id                String    @id @default(cuid())
  chatId            String
  userId            String
  joinedAt          DateTime  @default(now())
  lastReadMessageId String?
  lastReadAt        DateTime?
  unreadCount       Int       @default(0)
  chat              Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId, id])
  @@index([userId])
  @@index([userId, chatId])
}

model Message {
  id              String              @id @default(cuid())
  chatId          String
  senderId        String
  text            String
  clientMessageId String
  replyToMessageId String?
  createdAt       DateTime            @default(now())
  chat            Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender          User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo         Message?            @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies         Message[]           @relation("MessageReplies")
  attachments     MessageAttachment[]

  @@unique([chatId, clientMessageId])
  @@index([chatId, createdAt, id])
  @@index([chatId, createdAt, senderId])
  @@index([chatId, replyToMessageId])
}

model MessageAttachment {
  id           String     @id @default(cuid())
  messageId     String
  mediaAssetId  String
  createdAt     DateTime   @default(now())
  message       Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mediaAsset    MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([messageId, mediaAssetId])
  @@index([mediaAssetId])
}

model MediaAsset {
  id               String            @id @default(cuid())
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind             MediaAssetKind
  status           MediaAssetStatus  @default(pending)
  bucket           String
  objectKey        String            @unique
  mimeType         String
  byteSize         Int
  durationMs       Int?
  waveform         Float[]           @default([])
  originalFileName String
  publicUrl        String?
  error            String?
  chatId           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profileAvatar    Profile?          @relation("ProfileAvatar")
  profilePhotos    ProfilePhoto[]
  storyAsset       EventStory?
  posterCover      Poster?
  messageLinks     MessageAttachment[]

  @@index([ownerId, status, chatId])
  @@index([chatId, kind, status])
}

model Notification {
  id         String            @id @default(cuid())
  userId      String
  kind        NotificationKind
  title       String
  body        String
  chatId      String?
  messageId   String?
  eventId     String?
  requestId   String?
  actorUserId String?
  dedupeKey   String?
  payload     Json
  readAt      DateTime?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, readAt])
  @@index([userId, kind, readAt, chatId])
  @@index([userId, kind, readAt, actorUserId])
  @@index([userId, readAt, eventId, requestId])
  @@index([userId, createdAt, id])
  @@unique([dedupeKey])
}

model PushToken {
  id         String       @id @default(cuid())
  userId      String
  provider    PushProvider
  token       String       @unique
  deviceId    String?
  platform    String?
  disabledAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, disabledAt])
  @@index([userId, deviceId])
}

model OutboxEvent {
  id          String       @id @default(cuid())
  type        String
  payload     Json
  status      OutboxStatus @default(pending)
  availableAt DateTime     @default(now())
  attempts    Int          @default(0)
  lockedAt    DateTime?
  processedAt DateTime?
  lastError   String?
  createdAt   DateTime     @default(now())

  @@index([status, availableAt, createdAt])
  @@index([status, lockedAt])
}

model RealtimeEvent {
  id         BigInt   @id @default(autoincrement())
  chatId      String
  eventType   String
  payload     Json
  createdAt   DateTime @default(now())
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, id])
}

model TelegramBotState {
  id           String   @id
  lastUpdateId BigInt?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
