{
  "name": "@big-break/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node --transpile-only -r tsconfig-paths/register --project tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --runInBand test/unit",
    "test:integration": "jest --config jest.config.js --runInBand test/integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@big-break/contracts": "workspace:*",
    "@big-break/database": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@prisma/client": "^6.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.21.2",
    "ioredis": "^5.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "supertest": "^7.1.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.3",
    "@types/supertest": "^6.0.3"
  }
}
