{
  "name": "@big-break/chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "pnpm --filter @big-break/database prisma:generate",
    "prebuild": "pnpm --filter @big-break/database prisma:generate",
    "pretest": "pnpm --filter @big-break/database prisma:generate",
    "pretest:realtime": "pnpm --filter @big-break/database prisma:generate",
    "start": "ts-node --transpile-only -r tsconfig-paths/register --project tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "jest --config jest.config.js",
    "test:realtime": "jest --config jest.config.js --runInBand test/realtime"
  },
  "dependencies": {
    "@big-break/contracts": "workspace:*",
    "@big-break/database": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.6.0",
    "ioredis": "^5.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
