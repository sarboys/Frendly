          "expr": "histogram_quantile(0.95, sum(rate(frendly_http_request_duration_seconds_bucket{endpoint=~\"/events|/dating/discover|/chats/.*|/affiche/events|/evening/route-templates|/media/.*\"}[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}} p95"
        }
